# ─────────────────────────────────────────────────────────────
#  SmartRetail AI  — Frontend Environment Variables
#  Copy this file to .env.local and fill in real values.
#  NEVER commit the real .env.local to source control.
# ─────────────────────────────────────────────────────────────

# ── Backend API URL ───────────────────────────────────────────
# Development:  http://localhost:4000
# Production:   https://your-backend.vercel.app  (or Railway/Render URL)
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── JWT Secret (Edge Middleware) ──────────────────────────────
# Must exactly match JWT_SECRET in the backend .env.
# Used by Next.js Edge middleware to verify access_token cookie server-side.
# Optional in dev (falls back to hardcoded default).  REQUIRED in production.
JWT_SECRET="replace-with-strong-secret-min-32-chars"
